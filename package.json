{
  "name": "lintang-portal",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["client", "server"],
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "npm -w client run dev",
    "dev:server": "npm -w server run dev",
    "build": "npm -w client run build",
    "start": "NODE_ENV=production npm -w server run start",
    "seed": "npm -w server run seed",
    "reseed": "npm -w server run reseed",
    "setup": "npm install && npm run seed && npm run build"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
